PSEUDOCODE FOR VALUE ITERATION

VARIABLES

S            	-	set of states
A            	-	set of actions
P            	-	tells us what can happen after taking an action
R            	-	reward received after each move
V[s]         	-	value of a state s
pi[s]        	-	optimal action to take in state s
gamma        	-	how much we care about future rewards
epsilon      	-	how small changes must be before we stop
max_iterations	-  	maximum number of times to iterate
delta        	-	largest change in values in one round
delta_list   	-	list of delta for each round


FUNCTION GET_ACTIONS(P, s):
    # Return all actions available from state s
    IF s is in P:
        RETURN list of actions stored in P[s]
    ELSE:
        RETURN empty list


FUNCTION IS_TERMINAL(P, s):
    # A state is terminal if it has no actions
    IF GET_ACTIONS(P, s) is empty:
        RETURN True
    ELSE:
        RETURN False


FUNCTION ACTION_VALUE(s, a, P, R, V, gamma):
    # Compute expected value of taking action a in state s

    total <- 0 #Set initial totals to 0

    FOR EACH (s_next, prob) in P[s][a]:
        reward <- R[(s, a, s_next)]
        total <- total + prob * (reward + gamma * V[s_next])

    RETURN total


FUNCTION VALUE_ITERATION(S, A, P, R, gamma, epsilon, max_iterations):

    # Step 1: initialise all state values to 0
    FOR EACH state s in S:
        V[s] = 0

    delta_list <- empty list
    iteration <- 0


    # Step 2: repeat until convergence or max iterations
    WHILE iteration < max_iterations:

        iteration <- iteration + 1
        delta <- 0

        # create a copy so updates don’t affect current iteration
        V_new <- copy of V


        # Step 3: update each state value
        FOR EACH state s in S:

            IF s is terminal:
                CONTINUE

            best_value <- NONE

            # try all possible actions
            FOR EACH action a in GET_ACTIONS(P, s):

                val <- ACTION_VALUE(s, a, P, R, V, gamma)

                IF best_value is NONE OR val > best_value:
                    best_value <- val
 
            # update value and track maximum change
            change <- absolute value of (V[s] − best_value)
            delta <- maximum of (delta, change)

            V_new[s] <- best_value


        # Step 4: update values after full sweep
        V <- V_new
        append delta to delta_list

        # Step 5: check convergence
        IF delta < epsilon:
            BREAK


    # Step 6: extract optimal policy
    pi <- empty map

    FOR EACH state s in S:

        IF s is terminal:
            pi[s] <- NONE
            CONTINUE

        best_action <- NONE
        best_value <- NONE

        FOR EACH action a in GET_ACTIONS(P, s):

            val <- ACTION_VALUE(s, a, P, R, V, gamma)

            IF best_value is NONE OR val > best_value:
                best_value <- val
                best_action <- a

        pi[s] <- best_action


    RETURN pi, V, delta_list
    
SUMMARY

Value iteration updates V[s] using expected rewards and future values until convergence, then extracts the optimal policy pi.
